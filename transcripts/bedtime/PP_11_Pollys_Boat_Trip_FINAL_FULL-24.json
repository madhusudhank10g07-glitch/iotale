[
  { "text": "Pauly's boat trip.", "start": 0, "end": 1500 },
  { "text": "Grandpa Pig is taking", "start": 1600, "end": 2800 },
  { "text": "Peppa and George", "start": 2900, "end": 3900 },
  { "text": "on a boat trip.", "start": 4000, "end": 5000 },
  { "text": "Polly Parrot is going too.", "start": 5100, "end": 6500 },
  { "text": "Grandpa Pig,", "start": 6600, "end": 7200 },
  { "text": "have you got", "start": 7300, "end": 7900 },
  { "text": "your mobile phone?", "start": 8000, "end": 9000 },
  { "text": "Yes, Granny Pig.", "start": 9100, "end": 10000 },
  { "text": "Don't drop it", "start": 10100, "end": 11000 },
  { "text": "in the water.", "start": 11100, "end": 12000 },
  { "text": "No, Granny Pig.", "start": 12100, "end": 13000 },
  { "text": "Is it switched on?", "start": 13100, "end": 14000 },
  { "text": "Yes, Granny Pig.", "start": 14100, "end": 15000 },
  { "text": "Bye.", "start": 15100, "end": 15500 },
  { "text": "Bye-bye.", "start": 15600, "end": 16000 },
  { "text": "Grandad Dog is working", "start": 16100, "end": 17000 },
  { "text": "on his boat.", "start": 17100, "end": 18000 },
  { "text": "Oh, hoy there.", "start": 18100, "end": 19000 },
  { "text": "up.", "start": 19100, "end": 19500 },
  { "text": "Oh there.", "start": 19600, "end": 20000 },
  { "text": "Lovely day to go sailing.", "start": 20100, "end": 22000 },
  { "text": "I would go too,", "start": 22100, "end": 23500 },
  { "text": "but my boat needs a clean.", "start": 23600, "end": 25000 },
  { "text": "I don't know why", "start": 25100, "end": 26500 },
  { "text": "you bother cleaning", "start": 26600, "end": 27500 },
  { "text": "that rusty boat.", "start": 27600, "end": 29000 },
  { "text": "I'm surprised it's", "start": 29100, "end": 30000 },
  { "text": "still afloat.", "start": 30100, "end": 31000 },
  { "text": "This rusty boat", "start": 31100, "end": 32000 },
  { "text": "will still be afloat", "start": 32100, "end": 33500 },
  { "text": "long after your old tinbo", "start": 33600, "end": 35000 },
  { "text": "has sunk to the bottom", "start": 35100, "end": 36500 },
  { "text": "of the river.", "start": 36600, "end": 37500 },
  { "text": "Grandad Dog is", "start": 37600, "end": 38500 },
  { "text": "Grandpa Pig's very best friend.", "start": 38600, "end": 40500 },
  { "text": "Full steam ahead.", "start": 40600, "end": 42000 },
  { "text": "Goodbye.", "start": 42100, "end": 43000 },
  { "text": "I am the captain", "start": 43100, "end": 44500 },
  { "text": "of this boat", "start": 44600, "end": 45500 },
  { "text": "and when the captain", "start": 45600, "end": 47000 },
  { "text": "tells you to do something,", "start": 47100, "end": 48500 },
  { "text": "you must do it.", "start": 48600, "end": 50000 },
  { "text": "I I captain, Captain", "start": 50100, "end": 52000 },
  { "text": "Polly Parrot copies everything", "start": 52100, "end": 54000 },
  { "text": "that is said.", "start": 54100, "end": 55000 },
  { "text": "George, raise the flag.", "start": 55100, "end": 57000 },
  { "text": "George, raise the flag.", "start": 57100, "end": 59000 },
  { "text": "Peppa, ring the bell.", "start": 59100, "end": 61000 },
  { "text": "Peppa, ring the bell.", "start": 61100, "end": 63000 },
  { "text": "Grandpa, can I be", "start": 63100, "end": 64500 },
  { "text": "the captain, please?", "start": 64600, "end": 66000 },
  { "text": "Okay, but as captain,", "start": 66100, "end": 68000 },
  { "text": "you must wear this hat.", "start": 68100, "end": 70000 },
  { "text": "Peppa puts on", "start": 70100, "end": 71500 },
  { "text": "Grandpa Pig's hat.", "start": 71600, "end": 73000 },
  { "text": "Now she is the captain,", "start": 73100, "end": 75000 },
  { "text": "and everyone must do", "start": 75100, "end": 77000 },
  { "text": "what she says.", "start": 77100, "end": 78500 },
  { "text": "Turn that wheel.", "start": 78600, "end": 80000 },
  { "text": "I, Captain Peppa,", "start": 80100, "end": 81500 },
  { "text": "jump up and down.", "start": 81600, "end": 83000 },
  { "text": "Captain Peppa is a bit bossy.", "start": 83100, "end": 85000 },
  { "text": "Perhaps I should be", "start": 85100, "end": 87000 },
  { "text": "the captain again.", "start": 87100, "end": 88500 },
  { "text": "We don't want to", "start": 88600, "end": 90000 },
  { "text": "crash into anything.", "start": 90100, "end": 91500 },
  { "text": "Steering the boat", "start": 91600, "end": 93000 },
  { "text": "can be tricky.", "start": 93100, "end": 94500 },
  { "text": "Luckily, I'm good", "start": 94600, "end": 96000 },
  { "text": "at steering.", "start": 96100, "end": 97500 },
  { "text": "Oh dear.", "start": 97600, "end": 98500 },
  { "text": "Grandpa Pig's boat has crashed", "start": 98600, "end": 100500 },
  { "text": "into a little island.", "start": 100600, "end": 102000 },
  { "text": "Grandpa, we're stuck.", "start": 102100, "end": 103500 },
  { "text": "I'll ring Granny Pig.", "start": 103600, "end": 105000 },
  { "text": "She can get help.", "start": 105100, "end": 106500 },
  { "text": "Grandpa Pig did not spot", "start": 106600, "end": 108500 },
  { "text": "Polly Parrot on his shoulder.", "start": 108600, "end": 110500 },
  { "text": "Oh, Grandpa Pig has dropped", "start": 110600, "end": 112500 },
  { "text": "his phone in the water.", "start": 112600, "end": 114500 },
  { "text": "Granny Pig speaking.", "start": 114600, "end": 116000 },
  { "text": "Hello.", "start": 116100, "end": 117000 },
  { "text": "Hello.", "start": 117100, "end": 118000 },
  { "text": "Hello.", "start": 118100, "end": 119000 },
  { "text": "Somehow we need", "start": 119100, "end": 120500 },
  { "text": "to get a message", "start": 120600, "end": 122000 },
  { "text": "to Granny.", "start": 122100, "end": 123500 },
  { "text": "Ah, message to Granny.", "start": 123600, "end": 125000 },
  { "text": "Polly can fly to Granny.", "start": 125100, "end": 127000 },
  { "text": "Good idea, Peppa.", "start": 127100, "end": 128500 },
  { "text": "And I can teach Polly", "start": 128600, "end": 130500 },
  { "text": "what to say.", "start": 130600, "end": 132000 },
  { "text": "Grandpa Pig says,", "start": 132100, "end": 133500 },
  { "text": "Grandpa Pig says,", "start": 133600, "end": 135000 },
  { "text": "\"Help, help,", "start": 135100, "end": 136500 },
  { "text": "help, help.\"", "start": 136600, "end": 138000 },
  { "text": "There you see.", "start": 138100, "end": 139500 },
  { "text": "Easy peasy.", "start": 139600, "end": 141000 },
  { "text": "Grandpa Pig says,", "start": 141100, "end": 142500 },
  { "text": "\"Easy peasy.\"", "start": 142600, "end": 144000 },
  { "text": "You silly old bird.", "start": 144100, "end": 146000 },
  { "text": "You silly old bird.", "start": 146100, "end": 148000 },
  { "text": "Polly Parrot is flying", "start": 148100, "end": 150000 },
  { "text": "to Granny Pig's house.", "start": 150100, "end": 152000 },
  { "text": "Hello, Polly.", "start": 152100, "end": 153500 },
  { "text": "What are you doing here?", "start": 153600, "end": 155500 },
  { "text": "Grandpa Pig says,", "start": 155600, "end": 157000 },
  { "text": "\"What does Grandpa Pig say?\"", "start": 157100, "end": 159000 },
  { "text": "You silly old bird.", "start": 159100, "end": 161000 },
  { "text": "Oh, help.", "start": 161100, "end": 162500 },
  { "text": "Help!", "start": 162600, "end": 163500 },
  { "text": "Help!", "start": 163600, "end": 164500 },
  { "text": "Goodness me!", "start": 164600, "end": 166000 },
  { "text": "Grandpa must need help.", "start": 166100, "end": 168000 },
  { "text": "Granny Pig is driving", "start": 168100, "end": 170000 },
  { "text": "in her car", "start": 170100, "end": 171500 },
  { "text": "to find Grandad Dog.", "start": 171600, "end": 173500 },
  { "text": "Grandad Dog.", "start": 173600, "end": 175000 },
  { "text": "Hello, Granny Pig.", "start": 175100, "end": 177000 },
  { "text": "Grandpa Pig needs help.", "start": 177100, "end": 179000 },
  { "text": "Please, could you rescue him?", "start": 179100, "end": 181500 },
  { "text": "Madam, I would be delighted.", "start": 181600, "end": 184000 },
  { "text": "Grandad Dog and Granny Pig", "start": 184100, "end": 186500 },
  { "text": "are on their way", "start": 186600, "end": 188000 },
  { "text": "to save Grandpa Pig.", "start": 188100, "end": 190000 },
  { "text": "Hooray.", "start": 190100, "end": 191500 },
  { "text": "Hi there.", "start": 191600, "end": 193000 },
  { "text": "Do you need rescuing, Captain?", "start": 193100, "end": 195500 },
  { "text": "Um, maybe.", "start": 195600, "end": 197000 },
  { "text": "Would you like", "start": 197100, "end": 198500 },
  { "text": "my rusty old boat", "start": 198600, "end": 200500 },
  { "text": "to rescue you?", "start": 200600, "end": 202500 },
  { "text": "Yes, please, Grandad Dog.", "start": 202600, "end": 205000 },
  { "text": "Grandad Dog is throwing", "start": 205100, "end": 207000 },
  { "text": "Grandpa Pig a rope.", "start": 207100, "end": 209000 },
  { "text": "Catch this, Captain.", "start": 209100, "end": 211000 },
  { "text": "I I Skipper.", "start": 211100, "end": 213000 },
  { "text": "Grandad Dog pulls", "start": 213100, "end": 215000 },
  { "text": "Grandpa Pig's boat free.", "start": 215100, "end": 217000 },
  { "text": "Grandad Dog is", "start": 217100, "end": 219000 },
  { "text": "Grandpa Pig's very best friend.", "start": 219100, "end": 221500 },
  { "text": "Granny, did Polly tell you", "start": 221600, "end": 224000 },
  { "text": "we needed help?", "start": 224100, "end": 226000 },
  { "text": "Yes.", "start": 226100, "end": 227000 },
  { "text": "Polly is a very", "start": 227100, "end": 229000 },
  { "text": "clever parrot.", "start": 229100, "end": 230500 },
  { "text": "Say, 'I'm a clever parrot.'", "start": 230600, "end": 233000 },
  { "text": "I'm a clever parrot.", "start": 233100, "end": 235000 }
]