[
  { "text": "Champion", "start": 0, "end": 300 },
  { "text": "Daddy", "start": 320, "end": 600 },
  { "text": "Pig.", "start": 620, "end": 900 },
  { "text": "Peppa and", "start": 920, "end": 1500 },
  { "text": "her family", "start": 1520, "end": 2100 },
  { "text": "are watching", "start": 2120, "end": 2700 },
  { "text": "sport on", "start": 2720, "end": 3300 },
  { "text": "television.", "start": 3320, "end": 3600 },
  { "text": "It's a", "start": 3620, "end": 4200 },
  { "text": "long jump.", "start": 4220, "end": 4800 },
  { "text": "It's a new", "start": 4820, "end": 5700 },
  { "text": "world record.", "start": 5720, "end": 6300 },
  { "text": "Mommy, what's a", "start": 6320, "end": 7200 },
  { "text": "world record?", "start": 7220, "end": 7800 },
  { "text": "It means", "start": 7820, "end": 8400 },
  { "text": "you're best", "start": 8420, "end": 9000 },
  { "text": "in the world", "start": 9020, "end": 9900 },
  { "text": "at something.", "start": 9920, "end": 10500 },
  { "text": "Then you are", "start": 10520, "end": 11400 },
  { "text": "a champion", "start": 11420, "end": 12000 },
  { "text": "and your name", "start": 12020, "end": 12900 },
  { "text": "goes in", "start": 12920, "end": 13500 },
  { "text": "a book.", "start": 13520, "end": 14100 },
  { "text": "Daddy Pig", "start": 14120, "end": 14700 },
  { "text": "is showing", "start": 14720, "end": 15300 },
  { "text": "Peppa and George", "start": 15320, "end": 16200 },
  { "text": "the Book of", "start": 16220, "end": 17100 },
  { "text": "World Records.", "start": 17120, "end": 17700 },
  { "text": "There are", "start": 17720, "end": 18300 },
  { "text": "champions for", "start": 18320, "end": 18900 },
  { "text": "running, jumping,", "start": 18920, "end": 19500 },
  { "text": "swimming.", "start": 19520, "end": 19800 },
  { "text": "I wish", "start": 19820, "end": 20400 },
  { "text": "you were", "start": 20420, "end": 21000 },
  { "text": "in the book,", "start": 21020, "end": 21900 },
  { "text": "Daddy.", "start": 21920, "end": 22200 },
  { "text": "I am", "start": 22220, "end": 22800 },
  { "text": "in the book.", "start": 22820, "end": 23700 },
  { "text": "No.", "start": 23720, "end": 24000 },
  { "text": "Yes.", "start": 24020, "end": 24300 },
  { "text": "Daddy Pig is", "start": 24320, "end": 25200 },
  { "text": "champion puddle", "start": 25220, "end": 25800 },
  { "text": "jumper.", "start": 25820, "end": 26100 },
  { "text": "Wow.", "start": 26120, "end": 26400 },
  { "text": "No one has", "start": 26420, "end": 27300 },
  { "text": "beaten me yet.", "start": 27320, "end": 28200 },
  { "text": "I don't think", "start": 28220, "end": 29100 },
  { "text": "they ever will.", "start": 29120, "end": 30000 },
  { "text": "The next event", "start": 30020, "end": 30900 },
  { "text": "is the", "start": 30920, "end": 31500 },
  { "text": "puddle jump.", "start": 31520, "end": 32100 },
  { "text": "That was a", "start": 32120, "end": 33000 },
  { "text": "very big splash.", "start": 33020, "end": 33900 },
  { "text": "In fact,", "start": 33920, "end": 34500 },
  { "text": "I think", "start": 34520, "end": 35100 },
  { "text": "Yes, it's a", "start": 35120, "end": 36000 },
  { "text": "new world record.", "start": 36020, "end": 36900 },
  { "text": "Oh, daddy,", "start": 36920, "end": 37500 },
  { "text": "you're not the", "start": 37520, "end": 38400 },
  { "text": "champion anymore.", "start": 38420, "end": 39000 },
  { "text": "Everyone will", "start": 39020, "end": 39600 },
  { "text": "be sad.", "start": 39620, "end": 40200 },
  { "text": "Ho ho.", "start": 40220, "end": 40800 },
  { "text": "I'm sure", "start": 40820, "end": 41400 },
  { "text": "they've got more", "start": 41420, "end": 42300 },
  { "text": "important things", "start": 42320, "end": 42900 },
  { "text": "to worry about,", "start": 42920, "end": 43800 },
  { "text": "Peppa.", "start": 43820, "end": 44100 },
  { "text": "Daddy Pig,", "start": 44120, "end": 44700 },
  { "text": "you lost", "start": 44720, "end": 45300 },
  { "text": "the world record.", "start": 45320, "end": 45900 },
  { "text": "Everyone wants you", "start": 45920, "end": 46800 },
  { "text": "to be champion", "start": 46820, "end": 47700 },
  { "text": "again.", "start": 47720, "end": 48000 },
  { "text": "Really?", "start": 48020, "end": 48300 },
  { "text": "Yes.", "start": 48320, "end": 48600 },
  { "text": "Okay, I'll", "start": 48620, "end": 49200 },
  { "text": "do it tomorrow.", "start": 49220, "end": 50100 },
  { "text": "Hooray.", "start": 50120, "end": 50400 },
  { "text": "But I'll have", "start": 50420, "end": 51300 },
  { "text": "to train myself", "start": 51320, "end": 52200 },
  { "text": "to jump in", "start": 52220, "end": 53100 },
  { "text": "muddy puddles again.", "start": 53120, "end": 54000 },
  { "text": "Everyone knows", "start": 54020, "end": 54600 },
  { "text": "how to jump", "start": 54620, "end": 55500 },
  { "text": "in muddy", "start": 55520, "end": 56100 },
  { "text": "puddles, Daddy.", "start": 56120, "end": 56700 },
  { "text": "Ah, but", "start": 56720, "end": 57300 },
  { "text": "not everyone", "start": 57320, "end": 57900 },
  { "text": "is a champion,", "start": 57920, "end": 58800 },
  { "text": "Peppa.", "start": 58820, "end": 59100 },
  { "text": "Daddy Pig", "start": 59120, "end": 59700 },
  { "text": "is the master.", "start": 59720, "end": 60600 },
  { "text": "Daddy Pig, Peppa,", "start": 60620, "end": 61500 },
  { "text": "and George", "start": 61520, "end": 62100 },
  { "text": "are walking to", "start": 62120, "end": 63000 },
  { "text": "find a", "start": 63020, "end": 63600 },
  { "text": "muddy puddle.", "start": 63620, "end": 64200 },
  { "text": "Daddy, are you", "start": 64220, "end": 65100 },
  { "text": "going to practice", "start": 65120, "end": 66000 },
  { "text": "jumping up", "start": 66020, "end": 66600 },
  { "text": "and down?", "start": 66620, "end": 67200 },
  { "text": "No, Peppa.", "start": 67220, "end": 67800 },
  { "text": "I must be", "start": 67820, "end": 68700 },
  { "text": "at one", "start": 68720, "end": 69300 },
  { "text": "with the puddle.", "start": 69320, "end": 70200 },
  { "text": "What?", "start": 70220, "end": 70500 },
  { "text": "To jump", "start": 70520, "end": 71100 },
  { "text": "in a puddle,", "start": 71120, "end": 72000 },
  { "text": "I must think", "start": 72020, "end": 72900 },
  { "text": "like a paddle.", "start": 72920, "end": 73800 },
  { "text": "Do you need", "start": 73820, "end": 74700 },
  { "text": "to do running?", "start": 74720, "end": 75600 },
  { "text": "No.", "start": 75620, "end": 75900 },
  { "text": "Do you need", "start": 75920, "end": 76800 },
  { "text": "to do press ups?", "start": 76820, "end": 78000 },
  { "text": "No.", "start": 78020, "end": 78300 },
  { "text": "I need", "start": 78320, "end": 78900 },
  { "text": "to sleep", "start": 78920, "end": 79500 },
  { "text": "and dream", "start": 79520, "end": 80100 },
  { "text": "about puddles.", "start": 80120, "end": 80700 },
  { "text": "It is the day", "start": 80720, "end": 81900 },
  { "text": "of the big", "start": 81920, "end": 82800 },
  { "text": "puddle jump.", "start": 82820, "end": 83400 },
  { "text": "Daddy Pig", "start": 83420, "end": 84000 },
  { "text": "is wearing", "start": 84020, "end": 84600 },
  { "text": "his puddle", "start": 84620, "end": 85200 },
  { "text": "jumping costume.", "start": 85220, "end": 85800 },
  { "text": "I can't find", "start": 85820, "end": 86700 },
  { "text": "my golden boots.", "start": 86720, "end": 87600 },
  { "text": "I gave those", "start": 87620, "end": 88500 },
  { "text": "old boots", "start": 88520, "end": 89100 },
  { "text": "to Grandpa", "start": 89120, "end": 89700 },
  { "text": "for his gardening.", "start": 89720, "end": 90600 },
  { "text": "My lucky", "start": 90620, "end": 91200 },
  { "text": "golden boots.", "start": 91220, "end": 91800 },
  { "text": "to be used", "start": 91820, "end": 92700 },
  { "text": "as gardening boots.", "start": 92720, "end": 93600 },
  { "text": "You've got", "start": 93620, "end": 94200 },
  { "text": "other ones.", "start": 94220, "end": 94800 },
  { "text": "It's not", "start": 94820, "end": 95400 },
  { "text": "the same.", "start": 95420, "end": 96000 },
  { "text": "Mommy Pig", "start": 96020, "end": 96600 },
  { "text": "picks up", "start": 96620, "end": 97200 },
  { "text": "her phone", "start": 97220, "end": 97800 },
  { "text": "to call", "start": 97820, "end": 98400 },
  { "text": "Grandpa Pig.", "start": 98420, "end": 99000 },
  { "text": "Hello,", "start": 99020, "end": 99300 },
  { "text": "Grandpa.", "start": 99320, "end": 99600 },
  { "text": "Remember those", "start": 99620, "end": 100200 },
  { "text": "old boots", "start": 100220, "end": 100800 },
  { "text": "I gave you?", "start": 100820, "end": 101700 },
  { "text": "Uh, yes.", "start": 101720, "end": 102300 },
  { "text": "Daddy needs them", "start": 102320, "end": 103200 },
  { "text": "back urgently.", "start": 103220, "end": 103800 },
  { "text": "You have been", "start": 103820, "end": 104700 },
  { "text": "looking after them.", "start": 104720, "end": 105600 },
  { "text": "Um, they have", "start": 105620, "end": 106500 },
  { "text": "been watered.", "start": 106520, "end": 107100 },
  { "text": "Grandpa Pig", "start": 107120, "end": 107700 },
  { "text": "is growing tomatoes", "start": 107720, "end": 108600 },
  { "text": "in Daddy's", "start": 108620, "end": 109200 },
  { "text": "lucky boots.", "start": 109220, "end": 109800 },
  { "text": "We need them", "start": 109820, "end": 110400 },
  { "text": "for the", "start": 110420, "end": 111000 },
  { "text": "puddle jump today.", "start": 111020, "end": 112200 },
  { "text": "Right.", "start": 112220, "end": 112500 },
  { "text": "I'll meet you there.", "start": 112520, "end": 113700 },
  { "text": "Everyone has come", "start": 113720, "end": 114600 },
  { "text": "to watch", "start": 114620, "end": 115200 },
  { "text": "Daddy Pig's", "start": 115220, "end": 115800 },
  { "text": "puddle jump.", "start": 115820, "end": 116400 },
  { "text": "Please welcome", "start": 116420, "end": 117000 },
  { "text": "your friend", "start": 117020, "end": 117600 },
  { "text": "and mine,", "start": 117620, "end": 118200 },
  { "text": "Mr. Potato.", "start": 118220, "end": 118800 },
  { "text": "Hooray.", "start": 118820, "end": 119100 },
  { "text": "Good luck,", "start": 119120, "end": 119700 },
  { "text": "Daddy Pig.", "start": 119720, "end": 120300 },
  { "text": "Oh, but where", "start": 120320, "end": 121200 },
  { "text": "are your", "start": 121220, "end": 121800 },
  { "text": "lucky boots?", "start": 121820, "end": 122400 },
  { "text": "Here they are.", "start": 122420, "end": 123300 },
  { "text": "Thank you,", "start": 123320, "end": 123900 },
  { "text": "Grandpa Pig.", "start": 123920, "end": 124500 },
  { "text": "I can smell", "start": 124520, "end": 125400 },
  { "text": "tomatoes.", "start": 125420, "end": 125700 },
  { "text": "And now for", "start": 125720, "end": 126600 },
  { "text": "Daddy Pig's", "start": 126620, "end": 127200 },
  { "text": "puddle jump.", "start": 127220, "end": 127800 },
  { "text": "Daddy Pig", "start": 127820, "end": 128400 },
  { "text": "is thinking.", "start": 128420, "end": 129000 },
  { "text": "Ready,", "start": 129020, "end": 129300 },
  { "text": "steady,", "start": 129320, "end": 129600 },
  { "text": "go.", "start": 129620, "end": 129900 },
  { "text": "I must", "start": 129920, "end": 130500 },
  { "text": "become one", "start": 130520, "end": 131100 },
  { "text": "with the puddle.", "start": 131120, "end": 132000 },
  { "text": "I must be", "start": 132020, "end": 132900 },
  { "text": "the puddle.", "start": 132920, "end": 133500 },
  { "text": "The puddle", "start": 133520, "end": 134100 },
  { "text": "has gone.", "start": 134120, "end": 134700 },
  { "text": "The puddle", "start": 134720, "end": 135300 },
  { "text": "has gone", "start": 135320, "end": 135900 },
  { "text": "over all of us.", "start": 135920, "end": 137100 },
  { "text": "Daddy Pig", "start": 137120, "end": 137700 },
  { "text": "has become one", "start": 137720, "end": 138600 },
  { "text": "with the puddle.", "start": 138620, "end": 139500 },
  { "text": "Everyone has", "start": 139520, "end": 140100 },
  { "text": "become one", "start": 140120, "end": 140700 },
  { "text": "with the puddle.", "start": 140720, "end": 141600 },
  { "text": "It's a new", "start": 141620, "end": 142500 },
  { "text": "world record.", "start": 142520, "end": 143100 },
  { "text": "Hooray!", "start": 143120, "end": 143400 },
  { "text": "Champion", "start": 143420, "end": 143700 },
  { "text": "Daddy Pig.", "start": 143720, "end": 144300 },
  { "text": "And who", "start": 144320, "end": 144900 },
  { "text": "is this?", "start": 144920, "end": 145500 },
  { "text": "I'm Peppa Pig.", "start": 145520, "end": 146400 },
  { "text": "One day", "start": 146420, "end": 147000 },
  { "text": "I will be", "start": 147020, "end": 147900 },
  { "text": "the champion", "start": 147920, "end": 148500 },
  { "text": "puddle jumper.", "start": 148520, "end": 149100 },
  { "text": "I've been", "start": 149120, "end": 149700 },
  { "text": "training her.", "start": 149720, "end": 150300 },
  { "text": "Ah, to be", "start": 150320, "end": 151200 },
  { "text": "trained", "start": 151220, "end": 151500 },
  { "text": "by the master.", "start": 151520, "end": 152400 },
  { "text": "What have", "start": 152420, "end": 153000 },
  { "text": "you learned.", "start": 153020, "end": 153600 },
  { "text": "Uh, if you", "start": 153620, "end": 154500 },
  { "text": "jump in", "start": 154520, "end": 155100 },
  { "text": "muddy puddles,", "start": 155120, "end": 155700 },
  { "text": "you must wear", "start": 155720, "end": 156600 },
  { "text": "your boots.", "start": 156620, "end": 157200 }
]