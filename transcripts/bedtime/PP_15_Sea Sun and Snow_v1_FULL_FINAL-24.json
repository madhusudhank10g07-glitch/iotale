[
  { "text": "Sun, sea, and snow.", "start": 0, "end": 1500 },
  { "text": "It is bedtime for Peppa and George.", "start": 1500, "end": 3500 },
  { "text": "Tomorrow we are going on a coach trip to the seaside.", "start": 3500, "end": 6500 },
  { "text": "We can make sand castles.", "start": 6500, "end": 8000 },
  { "text": "I fancy a swim.", "start": 8000, "end": 9500 },
  { "text": "Me, too.", "start": 9500, "end": 10500 },
  { "text": "The weather forecast says it's going to be sunny.", "start": 10500, "end": 13500 },
  { "text": "Good night, Peppa.", "start": 13500, "end": 15000 },
  { "text": "Good night, George.", "start": 15000, "end": 16500 },
  { "text": "Oh, it is starting to snow.", "start": 16500, "end": 18500 },
  { "text": "It is Morning.", "start": 18500, "end": 19500 },
  { "text": "Yippee! It's sunny snow.", "start": 19500, "end": 21500 },
  { "text": "A lot of snow has fallen in the night.", "start": 21500, "end": 23500 },
  { "text": "Peppa and George run into Mommy and Daddy Pig's bedroom.", "start": 23500, "end": 26500 },
  { "text": "Snow! Mommy!", "start": 26500, "end": 28000 },
  { "text": "Snow! Daddy!", "start": 28000, "end": 29500 },
  { "text": "Snow! Snow! Snow!", "start": 29500, "end": 31500 },
  { "text": "What?", "start": 31500, "end": 32500 },
  { "text": "We are still going to the seaside, aren't we?", "start": 32500, "end": 35000 },
  { "text": "Well, let's see how much snow there is.", "start": 35000, "end": 37500 },
  { "text": "Daddy Pig walks outside to look at the snow.", "start": 37500, "end": 40500 },
  { "text": "Oh! Where's Daddy gone?", "start": 40500, "end": 42500 },
  { "text": "Daddy Pig is covered from head to toe in snow.", "start": 42500, "end": 45500 },
  { "text": "It's a walking snowman.", "start": 45500, "end": 47500 },
  { "text": "I'm cold.", "start": 47500, "end": 49000 },
  { "text": "It's a walking talking snowman.", "start": 49000, "end": 51500 },
  { "text": "Oh, it's just daddy.", "start": 51500, "end": 53500 },
  { "text": "Poor daddy.", "start": 53500, "end": 55000 },
  { "text": "Let's warm you up a bit.", "start": 55000, "end": 57000 },
  { "text": "Mommy Pig, Peppa, and George are warming Daddy Pig up", "start": 57000, "end": 60000 },
  { "text": "by rubbing him with towels.", "start": 60000, "end": 62000 },
  { "text": "That's better.", "start": 62000, "end": 63500 },
  { "text": "Now we can go to the sea. inside.", "start": 63500, "end": 66500 },
  { "text": "But what about the snow?", "start": 66500, "end": 68500 },
  { "text": "I don't think the coach will be running today.", "start": 68500, "end": 71500 },
  { "text": "Oh,", "start": 71500, "end": 72500 },
  { "text": "Miss Rabbit's coach has arrived at Peppa's house.", "start": 72500, "end": 75500 },
  { "text": "Goodness me.", "start": 75500, "end": 77000 },
  { "text": "How did you get through all that snow", "start": 77000, "end": 79500 },
  { "text": "with my big snow plow?", "start": 79500, "end": 81500 },
  { "text": "Snow plows push the snow out of the way.", "start": 81500, "end": 84500 },
  { "text": "Hello everyone.", "start": 84500, "end": 86000 },
  { "text": "Hello Peppa.", "start": 86000, "end": 87500 },
  { "text": "All of Peppa's friends are going to the seaside, too.", "start": 87500, "end": 90500 },
  { "text": "Next stop, the seaside.", "start": 90500, "end": 92500 },
  { "text": "Hooray.", "start": 92500, "end": 94000 },
  { "text": "Mr. Bull and his friends are gritting the road.", "start": 94000, "end": 97000 },
  { "text": "The grit melts the snow.", "start": 97000, "end": 99000 },
  { "text": "Hello, Mr. Bull.", "start": 99000, "end": 100500 },
  { "text": "Hello, Miss Rabbit.", "start": 100500, "end": 102500 },
  { "text": "It's taken us all night,", "start": 102500, "end": 104500 },
  { "text": "but the road is clear all the way to the seaside.", "start": 104500, "end": 107500 },
  { "text": "That's good.", "start": 107500, "end": 109000 },
  { "text": "We're going to the seaside.", "start": 109000, "end": 111000 },
  { "text": "Would you like to come along?", "start": 111000, "end": 113000 },
  { "text": "No thanks, Miss Rabbit.", "start": 113000, "end": 115000 },
  { "text": "We've got more roads to grit.", "start": 115000, "end": 117500 },
  { "text": "Goodbye.", "start": 117500, "end": 118500 },
  { "text": "Bye.", "start": 118500, "end": 119500 },
  { "text": "Have a lovely day at the beach.", "start": 119500, "end": 121500 },
  { "text": "We're all going on a seaside holiday swim.", "start": 121500, "end": 124500 },
  { "text": "We're all going on a season holiday.", "start": 124500, "end": 127500 },
  { "text": "Sea and sand and ice.", "start": 127500, "end": 129500 },
  { "text": "Here we are, the seaside.", "start": 129500, "end": 131500 },
  { "text": "The beach is covered in snow.", "start": 131500, "end": 134000 },
  { "text": "That sea looks cold.", "start": 134000, "end": 136000 },
  { "text": "I was looking forward to having a swim.", "start": 136000, "end": 138500 },
  { "text": "You still can. 10.", "start": 138500, "end": 140500 },
  { "text": "The sea's not frozen over.", "start": 140500, "end": 142500 },
  { "text": "Come along, girls.", "start": 142500, "end": 144500 },
  { "text": "What are you waiting for?", "start": 144500, "end": 146500 },
  { "text": "Um, I can't swim", "start": 146500, "end": 148500 },
  { "text": "because I've sprained my ankle", "start": 148500, "end": 150500 },
  { "text": "and I think I might have a cough.", "start": 150500, "end": 153000 },
  { "text": "Come on in, Mommy Pig.", "start": 153000, "end": 155000 },
  { "text": "It's lovely.", "start": 155000, "end": 156500 },
  { "text": "Are you sure it's lovely?", "start": 156500, "end": 158500 },
  { "text": "Of course.", "start": 158500, "end": 160000 },
  { "text": "The sea is wonderful today.", "start": 160000, "end": 162000 },
  { "text": "Okay, then.", "start": 162000, "end": 163500 },
  { "text": "Mummy Pig is going for a swim.", "start": 163500, "end": 165500 },
  { "text": "Is it cold, Mommy?", "start": 165500, "end": 167500 },
  { "text": "It's a little bit Cold.", "start": 167500, "end": 169500 },
  { "text": "It always feels cold when you first get in.", "start": 169500, "end": 172000 },
  { "text": "If you keep moving, you'll warm up.", "start": 172000, "end": 174500 },
  { "text": "Okay, I'll keep moving.", "start": 174500, "end": 176500 },
  { "text": "Mummy Pig has run out of the sea.", "start": 176500, "end": 179000 },
  { "text": "Let's get you dry.", "start": 179000, "end": 181000 },
  { "text": "Peppa, George, and Daddy Pig are warming Mummy Pig up", "start": 181000, "end": 184500 },
  { "text": "by rubbing her with towels.", "start": 184500, "end": 186500 },
  { "text": "Oh, that's better.", "start": 186500, "end": 188500 },
  { "text": "Are you going for a swim, Daddy Pig?", "start": 188500, "end": 191000 },
  { "text": "Maybe not today.", "start": 191000, "end": 193000 },
  { "text": "Who wants an ice cream?", "start": 193000, "end": 195000 },
  { "text": "Me.", "start": 195000, "end": 196000 },
  { "text": "Everyone likes ice creams at the seaside.", "start": 196000, "end": 199000 },
  { "text": "I wanted to make sand castles,", "start": 199000, "end": 201500 },
  { "text": "but the beach is covered in snow.", "start": 201500, "end": 204000 },
  { "text": "We can make snow castles.", "start": 204000, "end": 206000 },
  { "text": "First, we fill the buckets with snow.", "start": 206000, "end": 208500 },
  { "text": "We turn the buckets upside down,", "start": 208500, "end": 210500 },
  { "text": "give them a little tap,", "start": 210500, "end": 212500 },
  { "text": "and hey, presto, a snow castle.", "start": 212500, "end": 215000 },
  { "text": "Snow castles.", "start": 215000, "end": 216500 },
  { "text": "I love the seaside and I love the snow.", "start": 216500, "end": 219500 },
  { "text": "I love the seaside and the snow.", "start": 219500, "end": 222500 },
  { "text": "We're all going on a seaside holiday.", "start": 222500, "end": 225500 },
  { "text": "Santa Claus swimming in a sunny skies.", "start": 225500, "end": 228500 },
  { "text": "We're all going on a season holiday.", "start": 228500, "end": 231500 },
  { "text": "Sea and sand and ice.", "start": 231500, "end": 234000 }
]