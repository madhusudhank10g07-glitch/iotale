[
  { "text": "Shake, rattle, and bang.", "start": 0, "end": 1500 },
  { "text": "Peppa and her friends", "start": 1500, "end": 3000 },
  { "text": "are at play", "start": 3000, "end": 4200 },
  { "text": "with Madame Gazelle.", "start": 4200, "end": 5500 },
  { "text": "Today, children,", "start": 5500, "end": 6500 },
  { "text": "we are going to learn", "start": 6500, "end": 8000 },
  { "text": "about instruments", "start": 8000, "end": 9200 },
  { "text": "that you shake,", "start": 9200, "end": 10500 },
  { "text": "rattle, and bang.", "start": 10500, "end": 12000 },
  { "text": "Hooray!", "start": 12000, "end": 13000 },
  { "text": "First, choose an instrument", "start": 13000, "end": 15000 },
  { "text": "each from the music room.", "start": 15000, "end": 17000 },
  { "text": "I've got drums.", "start": 17000, "end": 18500 },
  { "text": "They are called bongo drums, Denny.", "start": 18500, "end": 21000 },
  { "text": "You bang them with your hands", "start": 21000, "end": 23000 },
  { "text": "like this.", "start": 23000, "end": 24000 },
  { "text": "Susie Sheep has found", "start": 24000, "end": 25500 },
  { "text": "an instrument.", "start": 25500, "end": 26500 },
  { "text": "I've got a flat bongo drum.", "start": 26500, "end": 28500 },
  { "text": "That is a boran.", "start": 28500, "end": 30000 },
  { "text": "It is Irish.", "start": 30000, "end": 31500 },
  { "text": "You beat it with a little stick", "start": 31500, "end": 34000 },
  { "text": "like this.", "start": 34000, "end": 35000 },
  { "text": "I've got a tambourine.", "start": 35000, "end": 37000 },
  { "text": "Very good, Pedro.", "start": 37000, "end": 38500 },
  { "text": "You can also shake it", "start": 38500, "end": 40500 },
  { "text": "like this.", "start": 40500, "end": 41500 },
  { "text": "Ooh,", "start": 41500, "end": 42500 },
  { "text": "Peppa has found", "start": 42500, "end": 44000 },
  { "text": "the biggest instrument.", "start": 44000, "end": 45500 },
  { "text": "I've got a big drum.", "start": 45500, "end": 47500 },
  { "text": "Huh?", "start": 47500, "end": 48500 },
  { "text": "The bass drum.", "start": 48500, "end": 50000 },
  { "text": "Meow.", "start": 50000, "end": 51000 },
  { "text": "I don't know", "start": 51000, "end": 52500 },
  { "text": "what this is called,", "start": 52500, "end": 54000 },
  { "text": "but it's scrapey.", "start": 54000, "end": 55500 },
  { "text": "That candy is called a hero,", "start": 55500, "end": 58000 },
  { "text": "and it comes all the way", "start": 58000, "end": 60500 },
  { "text": "from South America.", "start": 60500, "end": 62000 },
  { "text": "Wow.", "start": 62000, "end": 63000 },
  { "text": "How did it get here?", "start": 63000, "end": 65000 },
  { "text": "I brought it back", "start": 65000, "end": 66500 },
  { "text": "from my holiday.", "start": 66500, "end": 68000 },
  { "text": "Zoe Zebra is shaking", "start": 68000, "end": 70000 },
  { "text": "her instrument.", "start": 70000, "end": 71500 },
  { "text": "What are these?", "start": 71500, "end": 73000 },
  { "text": "They are maracas.", "start": 73000, "end": 74500 },
  { "text": "I brought them back", "start": 74500, "end": 76500 },
  { "text": "from my holiday in Spain.", "start": 76500, "end": 79000 },
  { "text": "This is is a triangle.", "start": 79000, "end": 81000 },
  { "text": "My dad sells these", "start": 81000, "end": 83000 },
  { "text": "in boxes of 10.", "start": 83000, "end": 85000 },
  { "text": "Thank you, Freddy.", "start": 85000, "end": 86500 },
  { "text": "I will remember that.", "start": 86500, "end": 88500 },
  { "text": "You don't need to go", "start": 88500, "end": 90500 },
  { "text": "on holiday to get them.", "start": 90500, "end": 92500 },
  { "text": "Thank you.", "start": 92500, "end": 93500 },
  { "text": "What has Emily Elephant found?", "start": 93500, "end": 96000 },
  { "text": "What are these?", "start": 96000, "end": 97500 },
  { "text": "These are castets.", "start": 97500, "end": 99000 },
  { "text": "My dad sells them", "start": 99000, "end": 100500 },
  { "text": "in boxes of five.", "start": 100500, "end": 102000 },
  { "text": "Thank you, Freddy.", "start": 102000, "end": 103500 },
  { "text": "Madame Gazelle is dancing", "start": 103500, "end": 105500 },
  { "text": "with the castanets.", "start": 105500, "end": 107000 },
  { "text": "Hey, that is how you play", "start": 107000, "end": 109500 },
  { "text": "the castanets.", "start": 109500, "end": 111000 },
  { "text": "Here you are, Emily.", "start": 111000, "end": 113000 },
  { "text": "Do I have to do the dance?", "start": 113000, "end": 115500 },
  { "text": "No, just make the", "start": 115500, "end": 117000 },
  { "text": "clickity clack noise.", "start": 117000, "end": 119000 },
  { "text": "Ah, I see Rebecca has symbols.", "start": 119000, "end": 122000 },
  { "text": "Yes.", "start": 122000, "end": 123000 },
  { "text": "Now you know what", "start": 123000, "end": 124500 },
  { "text": "your instruments sound like.", "start": 124500, "end": 126500 },
  { "text": "We can play them", "start": 126500, "end": 128000 },
  { "text": "all together.", "start": 128000, "end": 129500 },
  { "text": "Ready, steady, go.", "start": 129500, "end": 131500 },
  { "text": "Stop. Stop. Stop.", "start": 131500, "end": 133500 },
  { "text": "That is not music.", "start": 133500, "end": 135000 },
  { "text": "That is just noise.", "start": 135000, "end": 137000 },
  { "text": "Anybody can bang bang bang.", "start": 137000, "end": 139500 },
  { "text": "But to make music,", "start": 139500, "end": 141000 },
  { "text": "you have to listen", "start": 141000, "end": 142500 },
  { "text": "to each other", "start": 142500, "end": 144000 },
  { "text": "and keep in time.", "start": 144000, "end": 146000 },
  { "text": "Madam Gazelle,", "start": 146000, "end": 147500 },
  { "text": "I can't listen and do music.", "start": 147500, "end": 150000 },
  { "text": "Can you clap?", "start": 150000, "end": 151500 },
  { "text": "Yes.", "start": 151500, "end": 152500 },
  { "text": "If you can clap,", "start": 152500, "end": 154000 },
  { "text": "you can make music.", "start": 154000, "end": 156000 },
  { "text": "All the girls,", "start": 156000, "end": 157500 },
  { "text": "please copy me.", "start": 157500, "end": 159000 },
  { "text": "Now, boys,", "start": 159000, "end": 160500 },
  { "text": "Madame Gazelle has made", "start": 160500, "end": 162500 },
  { "text": "the clapping into music.", "start": 162500, "end": 164500 },
  { "text": "And stop.", "start": 164500, "end": 165500 },
  { "text": "Now we will learn", "start": 165500, "end": 167500 },
  { "text": "how to play", "start": 167500, "end": 169000 },
  { "text": "our instruments together.", "start": 169000, "end": 171000 },
  { "text": "The parents have come", "start": 171000, "end": 173000 },
  { "text": "to pick up the children.", "start": 173000, "end": 175500 },
  { "text": "Ah, you're just in time.", "start": 175500, "end": 178000 },
  { "text": "May I present", "start": 178000, "end": 179500 },
  { "text": "the Shake, Rattle, and Bang Orchestra.", "start": 179500, "end": 182500 },
  { "text": "Hooray.", "start": 182500, "end": 184000 },
  { "text": "Children, ready, steady, go.", "start": 184000, "end": 187000 },
  { "text": "Peppa and her friends", "start": 187000, "end": 189000 },
  { "text": "are performing.", "start": 189000, "end": 190500 },
  { "text": "for their grown-ups.", "start": 190500, "end": 192500 },
  { "text": "Bravo.", "start": 192500, "end": 193500 },
  { "text": "Perhaps some of my old pupils", "start": 193500, "end": 196500 },
  { "text": "would like to join in, too.", "start": 196500, "end": 199000 },
  { "text": "Madame Gazelle used to teach", "start": 199000, "end": 201500 },
  { "text": "all the mommies and daddies", "start": 201500, "end": 204000 },
  { "text": "when they were little.", "start": 204000, "end": 206000 },
  { "text": "Find your instruments, children.", "start": 206000, "end": 208500 },
  { "text": "Yes, Madame Gazelle.", "start": 208500, "end": 210500 },
  { "text": "Now the parents have", "start": 210500, "end": 212500 },
  { "text": "instruments, too.", "start": 212500, "end": 214000 },
  { "text": "It's quite hard, Daddy.", "start": 214000, "end": 216500 },
  { "text": "But you do it like This", "start": 216500, "end": 219000 },
  { "text": "Peppa is showing Daddy Pig", "start": 219000, "end": 221500 },
  { "text": "how to play the drums.", "start": 221500, "end": 224000 },
  { "text": "Let me see if", "start": 224000, "end": 225500 },
  { "text": "I've got that right.", "start": 225500, "end": 227500 },
  { "text": "Daddy Pig is very good", "start": 227500, "end": 229500 },
  { "text": "on the drums.", "start": 229500, "end": 231000 },
  { "text": "Daddy, you can play the drums.", "start": 231000, "end": 234000 },
  { "text": "I am a bit of", "start": 234000, "end": 235500 },
  { "text": "an expert at drumming.", "start": 235500, "end": 237500 },
  { "text": "That's good.", "start": 237500, "end": 238500 },
  { "text": "Shake, rattle, and banging.", "start": 238500, "end": 241000 },
  { "text": "Now for a tune.", "start": 241000, "end": 243000 },
  { "text": "Everybody is playing", "start": 243000, "end": 245000 },
  { "text": "their instruments together.", "start": 245000, "end": 247000 },
  { "text": "Daddy Pig is ready", "start": 247000, "end": 249000 },
  { "text": "for his drum solo.", "start": 249000, "end": 251000 },
  { "text": "My daddy can shake,", "start": 251000, "end": 253000 },
  { "text": "rattle, and bang.", "start": 253000, "end": 255000 }
]