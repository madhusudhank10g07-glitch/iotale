[
  { "text": "bedtime story.", "start": 0, "end": 1000 },
  { "text": "It is nighttime.", "start": 1000, "end": 2000 },
  { "text": "Daddy Pig is reading", "start": 2000, "end": 3500 },
  { "text": "Peppa and George", "start": 3500, "end": 4500 },
  { "text": "a her bedtime story.", "start": 4500, "end": 6000 },
  { "text": "And so the prince,", "start": 6000, "end": 7500 },
  { "text": "the princess, the budgie,", "start": 7500, "end": 9500 },
  { "text": "and the frog all", "start": 9500, "end": 11000 },
  { "text": "lived happily ever after.", "start": 11000, "end": 13000 },
  { "text": "The end.", "start": 13000, "end": 14000 },
  { "text": "The bedtime story", "start": 14000, "end": 15500 },
  { "text": "has sent Peppa", "start": 15500, "end": 16500 },
  { "text": "and George to sleep.", "start": 16500, "end": 18000 },
  { "text": "Good night, my little piggies.", "start": 18000, "end": 20500 },
  { "text": "George is awake.", "start": 20500, "end": 21500 },
  { "text": "Bye. door.", "start": 21500, "end": 22500 },
  { "text": "George, you naughty piggy.", "start": 22500, "end": 24500 },
  { "text": "Go back to sleep.", "start": 24500, "end": 26000 },
  { "text": "George is not sleepy.", "start": 26000, "end": 27500 },
  { "text": "George has got out of bed.", "start": 27500, "end": 29500 },
  { "text": "George", "start": 29500, "end": 30000 },
  { "text": "Peppa is trying to", "start": 30000, "end": 31500 },
  { "text": "put George back into bed.", "start": 31500, "end": 33500 },
  { "text": "Nighttime is for sleeping,", "start": 33500, "end": 35000 },
  { "text": "not playing.", "start": 35000, "end": 36000 },
  { "text": "I can tell you", "start": 36000, "end": 37500 },
  { "text": "a bedtime story.", "start": 37500, "end": 39000 },
  { "text": "Peppa has settled down", "start": 39000, "end": 40500 },
  { "text": "next to George's bed. head.", "start": 40500, "end": 42500 },
  { "text": "Once upon a time,", "start": 42500, "end": 44000 },
  { "text": "there was a little pig.", "start": 44000, "end": 46000 },
  { "text": "His name was Georgie Pig.", "start": 46000, "end": 48000 },
  { "text": "And he was off", "start": 48000, "end": 49000 },
  { "text": "to make his fortune.", "start": 49000, "end": 50500 },
  { "text": "Soon he came to a forest.", "start": 50500, "end": 52500 },
  { "text": "Do you like the story, George?", "start": 52500, "end": 54500 },
  { "text": "Inside the forest", "start": 54500, "end": 55500 },
  { "text": "was a little house.", "start": 55500, "end": 57000 },
  { "text": "And inside the house", "start": 57000, "end": 58500 },
  { "text": "was a bowl of porridge.", "start": 58500, "end": 60000 },
  { "text": "Georgie Pig was very hungry,", "start": 60000, "end": 62000 },
  { "text": "so he ate it all up.", "start": 62000, "end": 64000 },
  { "text": "Yum, yum, yum.", "start": 64000, "end": 65500 },
  { "text": "But just as he finished,", "start": 65500, "end": 67000 },
  { "text": "Baby Bear walked in and said,", "start": 67000, "end": 69000 },
  { "text": "\"Oi, did you eat", "start": 69000, "end": 70500 },
  { "text": "my magic porridge?\"", "start": 70500, "end": 72000 },
  { "text": "Georgie said, \"Yes.\"", "start": 72000, "end": 73500 },
  { "text": "Baby Bear said,", "start": 73500, "end": 74500 },
  { "text": "\"That was magic porridge.", "start": 74500, "end": 76000 },
  { "text": "It will make you go very big.\"", "start": 76000, "end": 78500 },
  { "text": "And then Georgie Pig", "start": 78500, "end": 80000 },
  { "text": "began to grow.", "start": 80000, "end": 81000 },
  { "text": "He grew and he grew", "start": 81000, "end": 82500 },
  { "text": "and he grew until", "start": 82500, "end": 84000 },
  { "text": "he was taller than", "start": 84000, "end": 85500 },
  { "text": "all of the trees in the forest.", "start": 85500, "end": 88000 },
  { "text": "The end.", "start": 88000, "end": 89000 },
  { "text": "Are you sleepy, George?", "start": 89000, "end": 90500 },
  { "text": "No, not even a little bit.", "start": 90500, "end": 92500 },
  { "text": "No.", "start": 92500, "end": 93000 },
  { "text": "Okay, I'll do a bit more story.", "start": 93000, "end": 95500 },
  { "text": "Baby bear said there is", "start": 95500, "end": 97000 },
  { "text": "a box of golden treasure", "start": 97000, "end": 99000 },
  { "text": "at the end of the world.", "start": 99000, "end": 101000 },
  { "text": "But it's too far", "start": 101000, "end": 102500 },
  { "text": "for me to go", "start": 102500, "end": 103500 },
  { "text": "because I'm too little.", "start": 103500, "end": 105000 },
  { "text": "Georgie said,", "start": 105000, "end": 106000 },
  { "text": "\"I will carry you there.\"", "start": 106000, "end": 108000 },
  { "text": "So Georgie Pig walked", "start": 108000, "end": 110000 },
  { "text": "to the end of the world.", "start": 110000, "end": 112000 },
  { "text": "He walked and he walked", "start": 112000, "end": 114000 },
  { "text": "and he walked.", "start": 114000, "end": 115000 },
  { "text": "Are you sleepy yet?", "start": 115000, "end": 116500 },
  { "text": "No.", "start": 116500, "end": 117000 },
  { "text": "He walked through forests,", "start": 117000, "end": 119000 },
  { "text": "across mountains, across seas.", "start": 119000, "end": 121500 },
  { "text": "And are you sleepy yet?", "start": 121500, "end": 123000 },
  { "text": "No.", "start": 123000, "end": 123500 },
  { "text": "He walked all the way", "start": 123500, "end": 125000 },
  { "text": "to the end of the world", "start": 125000, "end": 127000 },
  { "text": "and found a big box", "start": 127000, "end": 128500 },
  { "text": "of golden treasure.", "start": 128500, "end": 130000 },
  { "text": "Ooh, and a big dragon.", "start": 130000, "end": 132000 },
  { "text": "Yes, a big green dragon", "start": 132000, "end": 134000 },
  { "text": "with little wings", "start": 134000, "end": 135500 },
  { "text": "and breathing fire. Roar.", "start": 135500, "end": 137500 },
  { "text": "Luckily, it was", "start": 137500, "end": 138500 },
  { "text": "a very friendly dragon.", "start": 138500, "end": 140000 },
  { "text": "And he said,", "start": 140000, "end": 141000 },
  { "text": "\"You can have the treasure, but", "start": 141000, "end": 143500 },
  { "text": "Then Jordy Pig began to shrink.", "start": 143500, "end": 146000 },
  { "text": "He shrunk and he shrked", "start": 146000, "end": 148000 },
  { "text": "and he shrunk until", "start": 148000, "end": 149500 },
  { "text": "he was the same", "start": 149500, "end": 150500 },
  { "text": "little Jordy Pig as he was before.", "start": 150500, "end": 153000 },
  { "text": "\"How will we get back home now?\"", "start": 153000, "end": 155500 },
  { "text": "said Baby Bear.", "start": 155500, "end": 156500 },
  { "text": "\"I can fly you home,\"", "start": 156500, "end": 158500 },
  { "text": "said the dragon.", "start": 158500, "end": 159500 },
  { "text": "So Georgie Pig", "start": 159500, "end": 160500 },
  { "text": "and Baby Bear hooked", "start": 160500, "end": 162000 },
  { "text": "on the dragon's back", "start": 162000, "end": 163500 },
  { "text": "and flew all the way back home.", "start": 163500, "end": 166000 },
  { "text": "to the little house in the forest", "start": 166000, "end": 168500 },
  { "text": "and then it's the end.", "start": 168500, "end": 170500 },
  { "text": "George is asleep.", "start": 170500, "end": 172000 },
  { "text": "Peppa is asleep", "start": 172000, "end": 173500 },
  { "text": "next to George's bed.", "start": 173500, "end": 175000 },
  { "text": "Peppa, what are you doing", "start": 175000, "end": 177000 },
  { "text": "out of bed?", "start": 177000, "end": 178000 },
  { "text": "Nighttime is for sleeping,", "start": 178000, "end": 180000 },
  { "text": "not playing.", "start": 180000, "end": 181000 },
  { "text": "Daddy Pig picks Peppa up", "start": 181000, "end": 183500 },
  { "text": "and tucks her into bed.", "start": 183500, "end": 185500 },
  { "text": "Night night, my little piggies.", "start": 185500, "end": 188000 },
  { "text": "Sweet dreams.", "start": 188000, "end": 189000 },
  { "text": "Peppa and George", "start": 189000, "end": 190500 },
  { "text": "are in their little beds,", "start": 190500, "end": 192500 },
  { "text": "fast asleep.", "start": 192500, "end": 194000 }
]