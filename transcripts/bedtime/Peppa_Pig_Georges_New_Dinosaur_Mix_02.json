[
  { "text": "George's new dinosaur.", "start": 0, "end": 2000 },
  { "text": "George is playing", "start": 2500, "end": 4000 },
  { "text": "with his favorite toy,", "start": 4200, "end": 5800 },
  { "text": "Mr. Dinosaur.", "start": 6000, "end": 7200 },
  { "text": "Mr. Dinosaur is bouncy", "start": 7500, "end": 9000 },
  { "text": "like a ball.", "start": 9200, "end": 10500 },
  { "text": "George loves playing", "start": 10800, "end": 12200 },
  { "text": "with Mr. Dinosaur.", "start": 12400, "end": 13800 },
  { "text": "Mr. Dinosaur is", "start": 14200, "end": 15500 },
  { "text": "made of plastic.", "start": 15700, "end": 17000 },
  { "text": "It is almost", "start": 17300, "end": 18600 },
  { "text": "impossible to break him.", "start": 18800, "end": 20500 },
  { "text": "Dinosaur.", "start": 21000, "end": 22000 },
  { "text": "George. loves playing", "start": 22300, "end": 23800 },
  { "text": "with Mr. Dinosaur", "start": 24000, "end": 25400 },
  { "text": "in the bath.", "start": 25600, "end": 27000 },
  { "text": "At nighttime, George", "start": 27500, "end": 29000 },
  { "text": "always takes Mr. Dinosaur", "start": 29200, "end": 31000 },
  { "text": "to bed with him.", "start": 31200, "end": 33000 },
  { "text": "Dinosaur.", "start": 34000, "end": 35000 },
  { "text": "George. Mr. Dinosaur", "start": 35300, "end": 37000 },
  { "text": "is broken.", "start": 37200, "end": 38500 },
  { "text": "Oh,", "start": 39000, "end": 40000 },
  { "text": "Mr. Dinosaur does not", "start": 40200, "end": 42000 },
  { "text": "have a tail anymore.", "start": 42200, "end": 44000 },
  { "text": "Poor George.", "start": 44500, "end": 46000 },
  { "text": "You have had", "start": 46300, "end": 47800 },
  { "text": "Mr. Dinosaur a long time.", "start": 48000, "end": 50000 },
  { "text": "I'm surprised he lasted", "start": 50300, "end": 52000 },
  { "text": "as long as he did.", "start": 52200, "end": 54200 },
  { "text": "Maybe it's about time", "start": 54500, "end": 56500 },
  { "text": "you got a new dinosaur.", "start": 56700, "end": 58800 },
  { "text": "Yes, we can go", "start": 59200, "end": 61000 },
  { "text": "to Mr. Fox's shop tomorrow.", "start": 61200, "end": 63500 },
  { "text": "Peppa and her family", "start": 64000, "end": 65800 },
  { "text": "are at Mr. Fox's shop.", "start": 66000, "end": 68000 },
  { "text": "Mr. Fox's shop", "start": 68300, "end": 69800 },
  { "text": "sells everything.", "start": 70000, "end": 71500 },
  { "text": "Mr. Fox's shop is filled", "start": 71800, "end": 73800 },
  { "text": "with lots of things", "start": 74000, "end": 75800 },
  { "text": "like radios, rockets, clocks.", "start": 76000, "end": 78000 },
  { "text": "Oh, and a big dinosaur", "start": 78300, "end": 80300 },
  { "text": "in the window.", "start": 80500, "end": 82000 },
  { "text": "I'm sure we'll find you", "start": 82300, "end": 84300 },
  { "text": "a lovely new dinosaur here, George.", "start": 84500, "end": 87000 },
  { "text": "Dinosaur.", "start": 87500, "end": 88500 },
  { "text": "George does not want", "start": 88800, "end": 90800 },
  { "text": "a new dinosaur.", "start": 91000, "end": 92500 },
  { "text": "Look, George, a big dinosaur.", "start": 92800, "end": 95000 },
  { "text": "Dinosaur.", "start": 95300, "end": 96300 },
  { "text": "Good morning.", "start": 96600, "end": 98000 },
  { "text": "Can I help you?", "start": 98200, "end": 100000 },
  { "text": "We'd like the dinosaur", "start": 100300, "end": 102300 },
  { "text": "in the window, please.", "start": 102500, "end": 104500 },
  { "text": "Certainly. Good choice.", "start": 104800, "end": 106500 },
  { "text": "This is the dino roar.", "start": 106800, "end": 108800 },
  { "text": "It roars, it walks,", "start": 109000, "end": 111000 },
  { "text": "and it sings a dinosaur song.", "start": 111200, "end": 113800 },
  { "text": "Dino roar. Dino roar.", "start": 114000, "end": 116000 },
  { "text": "Listen to the dino roar.", "start": 116200, "end": 118200 },
  { "text": "Roar.", "start": 118500, "end": 119800 },
  { "text": "Wow.", "start": 120200, "end": 121500 },
  { "text": "Wow. Dino roar.", "start": 121800, "end": 123500 },
  { "text": "We'll take it.", "start": 123800, "end": 125500 },
  { "text": "Roar.", "start": 125800, "end": 127000 },
  { "text": "George is in the garden.", "start": 127300, "end": 129500 },
  { "text": "He is trying to bounce", "start": 129700, "end": 131800 },
  { "text": "Dino Roar like a ball.", "start": 132000, "end": 134200 },
  { "text": "Don't play too roughly", "start": 134500, "end": 136500 },
  { "text": "with Dino Roar, George.", "start": 136700, "end": 138700 },
  { "text": "He has moving parts", "start": 139000, "end": 140800 },
  { "text": "and might get broken.", "start": 141000, "end": 142800 },
  { "text": "George cannot play", "start": 143200, "end": 144800 },
  { "text": "with Dino Roar", "start": 145000, "end": 146500 },
  { "text": "in the garden.", "start": 146700, "end": 148500 },
  { "text": "Oh,", "start": 149000, "end": 150200 },
  { "text": "George wants to play", "start": 150500, "end": 152300 },
  { "text": "with Dino Roar in the bath.", "start": 152500, "end": 155000 },
  { "text": "George, if you get", "start": 155300, "end": 157300 },
  { "text": "Dino Roar wet,", "start": 157500, "end": 159300 },
  { "text": "he'll stop working.", "start": 159500, "end": 161500 },
  { "text": "George cannot play", "start": 161800, "end": 163500 },
  { "text": "with Dino Roar in the bath.", "start": 163700, "end": 166200 },
  { "text": "It is nighttime.", "start": 166600, "end": 168300 },
  { "text": "George has taken Dino Roar", "start": 168500, "end": 170800 },
  { "text": "to bed with him.", "start": 171000, "end": 173000 },
  { "text": "Roar.", "start": 173500, "end": 174800 },
  { "text": "George.", "start": 175200, "end": 176500 },
  { "text": "Dino.", "start": 176800, "end": 178000 },
  { "text": "Dino Roar has woken me up.", "start": 178300, "end": 180800 },
  { "text": "Maybe Dino Roar should sleep", "start": 181000, "end": 183300 },
  { "text": "somewhere else.", "start": 183500, "end": 185300 },
  { "text": "To the dino.", "start": 185600, "end": 187200 },
  { "text": "George cannot have Dino Roar", "start": 187500, "end": 189800 },
  { "text": "in his bed at night.", "start": 190000, "end": 192000 },
  { "text": "It is morning.", "start": 192500, "end": 194000 },
  { "text": "Why is George looking so sad?", "start": 194300, "end": 196800 },
  { "text": "George cannot play with Dino Roar", "start": 197000, "end": 199800 },
  { "text": "in the garden, in the bath,", "start": 200000, "end": 202500 },
  { "text": "or in bed.", "start": 202700, "end": 204200 },
  { "text": "Never mind, George.", "start": 204500, "end": 206200 },
  { "text": "Dino Roar can still roar.", "start": 206500, "end": 208800 },
  { "text": "Dino roar. Dino roar.", "start": 209000, "end": 211000 },
  { "text": "Listen to the Dino roar.", "start": 211200, "end": 213500 },
  { "text": "Oh,", "start": 213800, "end": 215000 },
  { "text": "I think the batteries", "start": 215300, "end": 217300 },
  { "text": "must have run out, Daddy Pig.", "start": 217500, "end": 220000 },
  { "text": "Already?", "start": 220300, "end": 221800 },
  { "text": "How many batteries are in here?", "start": 222000, "end": 224500 },
  { "text": "Hundreds and thousands.", "start": 224800, "end": 226800 },
  { "text": "Dino Roar needs lots of batteries", "start": 227000, "end": 229500 },
  { "text": "to make him roar.", "start": 229700, "end": 231700 },
  { "text": "Peppa has found something", "start": 232000, "end": 234000 },
  { "text": "under a bush.", "start": 234200, "end": 235800 },
  { "text": "Oh, what's this?", "start": 236000, "end": 237800 },
  { "text": "A trumpet.", "start": 238000, "end": 239500 },
  { "text": "That doesn't sound like a trumpet.", "start": 241000, "end": 243500 },
  { "text": "It doesn't work.", "start": 243700, "end": 245500 },
  { "text": "Dinosaur.", "start": 245800, "end": 247000 },
  { "text": "That's not a trumpet, Peppa.", "start": 247300, "end": 249500 },
  { "text": "You found Mr. Dinosaur's tail.", "start": 249700, "end": 252000 },
  { "text": "Oh, now Daddy Pig can mend him.", "start": 252300, "end": 255000 },
  { "text": "I'll try.", "start": 255300, "end": 256800 },
  { "text": "I think it might be", "start": 258300, "end": 260300 },
  { "text": "quite difficult to mend.", "start": 260500, "end": 262500 },
  { "text": "Oh,", "start": 262800, "end": 264000 },
  { "text": "Daddy Pig has mended", "start": 264300, "end": 266300 },
  { "text": "Mr. Dinosaur.", "start": 266500, "end": 268000 },
  { "text": "Hooray.", "start": 268300, "end": 269800 },
  { "text": "Ho ho.", "start": 270000, "end": 271500 },
  { "text": "I am a bit of an expert", "start": 271800, "end": 274300 },
  { "text": "at mending things.", "start": 274500, "end": 276500 },
  { "text": "George loves Mr. Dinosaur.", "start": 276800, "end": 279000 },
  { "text": "Dinosaur. Dinosaur. Dinosaur.", "start": 279300, "end": 281500 },
  { "text": "Hello, Mr. Dinosaur.", "start": 281800, "end": 283500 },
  { "text": "Mr. Dinosaur is George's", "start": 283800, "end": 286000 },
  { "text": "favorite toy in the whole world.", "start": 286200, "end": 289000 },
  { "text": "Dinosaur. Dinosaur.", "start": 289300, "end": 291000 },
  { "text": "Hello, Mr. Dinosaur.", "start": 291300, "end": 293000 },
  { "text": "Dinosaur. Dinosaur.", "start": 293300, "end": 295000 },
  { "text": "Hello, Mr. Dinosaur.", "start": 295300, "end": 297000 }
]