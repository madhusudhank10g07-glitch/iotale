[
  { "text": "Mr. Bull's new road.", "start": 0, "end": 1500 },
  { "text": "Peppa is taking Goldie", "start": 1600, "end": 3000 },
  { "text": "the Fish to the vet", "start": 3100, "end": 4500 },
  { "text": "for a checkup.", "start": 4600, "end": 5500 },
  { "text": "I like this road.", "start": 5600, "end": 7000 },
  { "text": "It's all wibbly wobbly.", "start": 7100, "end": 8500 },
  { "text": "Goldie likes it, too.", "start": 8600, "end": 10000 },
  { "text": "The fish in the bowl", "start": 10100, "end": 11500 },
  { "text": "swims and rounds", "start": 11600, "end": 13000 },
  { "text": "and rounds and stop.", "start": 13100, "end": 14500 },
  { "text": "Mr. Bull is blocking", "start": 14600, "end": 16000 },
  { "text": "the road.", "start": 16100, "end": 17000 },
  { "text": "What are you doing,", "start": 17100, "end": 18500 },
  { "text": "Mr. Bull?", "start": 18600, "end": 19500 },
  { "text": "We're digging up", "start": 19600, "end": 21000 },
  { "text": "this old road.", "start": 21100, "end": 22500 },
  { "text": "road to make a new one.", "start": 22600, "end": 24500 },
  { "text": "Will it be wibbly wobbly", "start": 24600, "end": 26500 },
  { "text": "like the old road?", "start": 26600, "end": 28000 },
  { "text": "No, Peppa,", "start": 28100, "end": 29000 },
  { "text": "it will be straight.", "start": 29100, "end": 30500 },
  { "text": "The workers are busy", "start": 30600, "end": 32000 },
  { "text": "making the wibbly wobbly", "start": 32100, "end": 33500 },
  { "text": "road straight.", "start": 33600, "end": 34500 },
  { "text": "Now, if you'll excuse me,", "start": 34600, "end": 36500 },
  { "text": "I've got a bit", "start": 36600, "end": 38000 },
  { "text": "of shouting to do.", "start": 38100, "end": 39500 },
  { "text": "Come on, let's go", "start": 39600, "end": 41000 },
  { "text": "move on.", "start": 41100, "end": 42000 },
  { "text": "Mr. Bull is the boss.", "start": 42100, "end": 43500 },
  { "text": "Bosses like to shout.", "start": 43600, "end": 45000 },
  { "text": "Keep up the good work.", "start": 45100, "end": 46500 },
  { "text": "But how will we get", "start": 46600, "end": 48000 },
  { "text": "Goldie to the vets?", "start": 48100, "end": 49500 },
  { "text": "We'll just have to", "start": 49600, "end": 51000 },
  { "text": "walk there.", "start": 51100, "end": 52000 },
  { "text": "Peppa and Goldie", "start": 52100, "end": 53500 },
  { "text": "have arrived at", "start": 53600, "end": 54500 },
  { "text": "Dr. Hamster, the vets.", "start": 54600, "end": 56000 },
  { "text": "Dr. Hamster helps", "start": 56100, "end": 57500 },
  { "text": "sick pets get better.", "start": 57600, "end": 59000 },
  { "text": "Hello, Dr. Hamster.", "start": 59100, "end": 60500 },
  { "text": "I've brought Goldie", "start": 60600, "end": 62000 },
  { "text": "the fish for her checkup.", "start": 62100, "end": 64000 },
  { "text": "Dr. Hamster is looking", "start": 64100, "end": 65500 },
  { "text": "at Goldie in her fishbowl.", "start": 65600, "end": 67500 },
  { "text": "Aw, she's love.", "start": 67600, "end": 69000 },
  { "text": "Is that the checkup?", "start": 69100, "end": 70500 },
  { "text": "Yes.", "start": 70600, "end": 71500 },
  { "text": "Just make sure", "start": 71600, "end": 72500 },
  { "text": "she drinks", "start": 72600, "end": 73500 },
  { "text": "plenty of water.", "start": 73600, "end": 75000 },
  { "text": "Oh, hello Mr. Bull.", "start": 75100, "end": 76500 },
  { "text": "Hello, Dr. Amster.", "start": 76600, "end": 78000 },
  { "text": "Sorry about the noise.", "start": 78100, "end": 79500 },
  { "text": "We're building a new road.", "start": 79600, "end": 81000 },
  { "text": "Will you take long?", "start": 81100, "end": 82500 },
  { "text": "No, not long.", "start": 82600, "end": 84000 },
  { "text": "We just have to", "start": 84100, "end": 85500 },
  { "text": "knock this building down.", "start": 85600, "end": 87500 },
  { "text": "Mr. Bull wants to", "start": 87600, "end": 89000 },
  { "text": "knock down the vet surgery.", "start": 89100, "end": 91000 },
  { "text": "You can't knock", "start": 91100, "end": 92500 },
  { "text": "this building down.", "start": 92600, "end": 94000 },
  { "text": "No, this is where", "start": 94100, "end": 95500 },
  { "text": "Polly Pets come", "start": 95600, "end": 97000 },
  { "text": "to get better.", "start": 97100, "end": 98500 },
  { "text": "Is it?", "start": 98600, "end": 99500 },
  { "text": "Yes.", "start": 99600, "end": 100500 },
  { "text": "Can't you make the rod", "start": 100600, "end": 102000 },
  { "text": "go around the building?", "start": 102100, "end": 103500 },
  { "text": "instead", "start": 103600, "end": 104500 },
  { "text": "around the building around.", "start": 104600, "end": 106500 },
  { "text": "But then the road", "start": 106600, "end": 108000 },
  { "text": "wouldn't be straight.", "start": 108100, "end": 109500 },
  { "text": "Busy people can't be", "start": 109600, "end": 111000 },
  { "text": "wasting time driving", "start": 111100, "end": 112500 },
  { "text": "around things.", "start": 112600, "end": 114000 },
  { "text": "If you can't go around it,", "start": 114100, "end": 116000 },
  { "text": "then can you go over it?", "start": 116100, "end": 118000 },
  { "text": "No, that would be silly.", "start": 118100, "end": 120000 },
  { "text": "What about going underneath it?", "start": 120100, "end": 122500 },
  { "text": "Oh, a tunnel.", "start": 122600, "end": 124000 },
  { "text": "That's very hard to do.", "start": 124100, "end": 126000 },
  { "text": "Oh, someone's at the back door.", "start": 126100, "end": 128500 },
  { "text": "Oh, hello.", "start": 128600, "end": 129500 },
  { "text": "Hello,", "start": 129600, "end": 130500 },
  { "text": "it is Mr. Bull's brother.", "start": 130600, "end": 132500 },
  { "text": "Hello.", "start": 132600, "end": 133500 },
  { "text": "Sorry about the noise,", "start": 133600, "end": 135000 },
  { "text": "but we're building a road", "start": 135100, "end": 137000 },
  { "text": "and need to knock", "start": 137100, "end": 138500 },
  { "text": "this building down.", "start": 138600, "end": 140000 },
  { "text": "Dr. Hamster's Home", "start": 140100, "end": 141500 },
  { "text": "for Sick Pets", "start": 141600, "end": 143000 },
  { "text": "is in the way", "start": 143100, "end": 144500 },
  { "text": "of the new road.", "start": 144600, "end": 146000 },
  { "text": "Hello everyone.", "start": 146100, "end": 147500 },
  { "text": "Mr. Rabbit is the", "start": 147600, "end": 149000 },
  { "text": "road building inspector.", "start": 149100, "end": 150500 },
  { "text": "H things are looking", "start": 150600, "end": 152000 },
  { "text": "a bit slack.", "start": 152100, "end": 153500 },
  { "text": "Mr. Bull, why have you", "start": 153600, "end": 155000 },
  { "text": "stopped working?", "start": 155100, "end": 156500 },
  { "text": "This building is in the way.", "start": 156600, "end": 158500 },
  { "text": "I said they should", "start": 158600, "end": 160000 },
  { "text": "build a tunnel.", "start": 160100, "end": 161500 },
  { "text": "Yes, a tunnel.", "start": 161600, "end": 163000 },
  { "text": "tunnel would do.", "start": 163100, "end": 164500 },
  { "text": "Yes, but that would be", "start": 164600, "end": 166500 },
  { "text": "very hard to do.", "start": 166600, "end": 168000 },
  { "text": "Are your machines", "start": 168100, "end": 169500 },
  { "text": "not strong enough", "start": 169600, "end": 171000 },
  { "text": "to make a tunnel?", "start": 171100, "end": 172500 },
  { "text": "What?", "start": 172600, "end": 173500 },
  { "text": "Our machines are", "start": 173600, "end": 175000 },
  { "text": "the strongest machines", "start": 175100, "end": 176500 },
  { "text": "in the world.", "start": 176600, "end": 178000 },
  { "text": "We can build a tunnel.", "start": 178100, "end": 180000 },
  { "text": "Mr. Bull and his brother", "start": 180100, "end": 182000 },
  { "text": "are going to work together.", "start": 182100, "end": 184500 },
  { "text": "I'll dig from this side.", "start": 184600, "end": 186500 },
  { "text": "I'll dig from the other side.", "start": 186600, "end": 188500 },
  { "text": "And we'll meet", "start": 188600, "end": 190000 },
  { "text": "in the middle.", "start": 190100, "end": 191500 },
  { "text": "Mr. Bull and his brother", "start": 191600, "end": 193500 },
  { "text": "are digging a tunnel.", "start": 193600, "end": 195500 },
  { "text": "through the hill.", "start": 195600, "end": 197000 },
  { "text": "The tunnel has been dug", "start": 197100, "end": 199000 },
  { "text": "and the new road", "start": 199100, "end": 200500 },
  { "text": "is finished.", "start": 200600, "end": 202000 },
  { "text": "Hooray!", "start": 202100, "end": 203500 },
  { "text": "Congratulations, Mr. Bull.", "start": 203600, "end": 205500 },
  { "text": "You did a fine job.", "start": 205600, "end": 207500 },
  { "text": "Yes.", "start": 207600, "end": 208500 },
  { "text": "Now all those busy people", "start": 208600, "end": 210500 },
  { "text": "can get to where", "start": 210600, "end": 212000 },
  { "text": "they're going more quickly.", "start": 212100, "end": 214000 },
  { "text": "The new road is so", "start": 214100, "end": 215500 },
  { "text": "nice and straight.", "start": 215600, "end": 217000 },
  { "text": "that lots and lots", "start": 217100, "end": 218500 },
  { "text": "of cars have come", "start": 218600, "end": 220000 },
  { "text": "to use it.", "start": 220100, "end": 221500 },
  { "text": "Uh, they're not going", "start": 221600, "end": 223500 },
  { "text": "that quickly.", "start": 223600, "end": 225000 },
  { "text": "H, there are more cars", "start": 225100, "end": 227000 },
  { "text": "using this road", "start": 227100, "end": 228500 },
  { "text": "than we had planned for.", "start": 228600, "end": 230500 },
  { "text": "We'll need a bigger road.", "start": 230600, "end": 232500 },
  { "text": "So, what are you", "start": 232600, "end": 234000 },
  { "text": "going to do?", "start": 234100, "end": 235500 },
  { "text": "Only one thing", "start": 235600, "end": 237000 },
  { "text": "we can do, Peppa.", "start": 237100, "end": 238500 },
  { "text": "We'll dig up the road.", "start": 238600, "end": 240500 },
  { "text": "Peppa and George love it", "start": 240600, "end": 242500 },
  { "text": "when Mr. Bull and his brother", "start": 242600, "end": 245000 },
  { "text": "dig up the road.", "start": 245100, "end": 246500 },
  { "text": "Everyone loves it", "start": 246600, "end": 248000 },
  { "text": "when Mr. Bull and his brother", "start": 248100, "end": 250500 },
  { "text": "dig up the road.", "start": 250600, "end": 252000 }
]